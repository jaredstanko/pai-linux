#!/bin/bash
# pai-status — Show PAI sandbox health and version info
#
# Usage:
#   pai-status                 # Status of default instance
#   pai-status --name=v2       # Status of named instance

set -euo pipefail

# Source shared instance configuration
_PAI_LIB="$HOME/.local/lib/pai/common.sh"
if [ -f "$_PAI_LIB" ]; then
  source "$_PAI_LIB" "$@"
else
  CONTAINER_NAME="pai" INSTANCE_NAME="pai" INSTANCE_SUFFIX="" _PAI_NAME=""
  BOLD='\033[1m' GREEN='\033[0;32m' YELLOW='\033[1;33m' RED='\033[0;31m' CYAN='\033[0;36m' NC='\033[0m'
fi

# Check prerequisites
if ! command -v incus &>/dev/null; then
  echo -e "${RED}✗${NC} Incus not found. Run install.sh first."
  exit 1
fi
if ! incus info "$CONTAINER_NAME" &>/dev/null 2>&1; then
  echo -e "${RED}✗${NC} Container '$CONTAINER_NAME' does not exist. Run install.sh first."
  exit 1
fi

echo ""
echo -e "${BOLD}${CYAN}═══════════════════════════════════════════════${NC}"
echo -e "${BOLD}  PAI-Incus — Status${NC}"
if [ -n "$INSTANCE_SUFFIX" ]; then
  echo -e "${BOLD}  Instance: ${CYAN}${INSTANCE_NAME}${NC}"
fi
echo -e "${BOLD}${CYAN}═══════════════════════════════════════════════${NC}"
echo ""

# Cache container info (single call)
CONTAINER_INFO=$(incus info "$CONTAINER_NAME" 2>/dev/null)
STATUS=$(echo "$CONTAINER_INFO" | grep "^Status:" | awk '{print $2}')

case "$STATUS" in
  RUNNING)
    echo -e "  Container:  ${GREEN}● RUNNING${NC}"
    ;;
  STOPPED)
    echo -e "  Container:  ${RED}● STOPPED${NC}"
    echo ""
    echo "  Run ${BOLD}pai-start${INSTANCE_SUFFIX:+ --name=${_PAI_NAME:-}}${NC} to start the sandbox."
    exit 0
    ;;
  *)
    echo -e "  Container:  ${YELLOW}● $STATUS${NC}"
    exit 1
    ;;
esac

# Resource usage
echo ""
echo -e "  ${BOLD}Resources${NC}"
CPU_LIMIT=$(incus config get "$CONTAINER_NAME" limits.cpu 2>/dev/null || echo "default")
MEM_LIMIT=$(incus config get "$CONTAINER_NAME" limits.memory 2>/dev/null || echo "default")
echo "  CPU limit:  $CPU_LIMIT"
echo "  Mem limit:  $MEM_LIMIT"

DISK_INFO=$(echo "$CONTAINER_INFO" | grep -A2 "root:" || echo "")
if [ -n "$DISK_INFO" ]; then
  echo "  Disk:       $(echo "$DISK_INFO" | grep "Space used" | awk '{print $3, $4}' || echo 'N/A')"
fi

CREATED=$(echo "$CONTAINER_INFO" | grep "^Created:" | sed 's/Created: *//')
if [ -n "$CREATED" ]; then
  echo "  Created:    $CREATED"
fi

# Batch all container-internal checks into a single exec call
echo ""
echo -e "  ${BOLD}Tool Versions${NC}"

VM_CHECK_SCRIPT='
  echo "BUN=$(bun --version 2>/dev/null || echo MISSING)"
  echo "CLAUDE=$(claude --version 2>/dev/null | grep -oE "[0-9.]+" | head -1 || echo MISSING)"
  echo "NODE=$(node --version 2>/dev/null || echo MISSING)"
  echo "PAI=$(test -d /home/claude/.claude/PAI && echo YES || echo NO)"
  echo "COMPANION=$(test -d /home/claude/pai-companion/companion && echo YES || echo NO)"
  if [ -S /tmp/pipewire-0 ]; then echo "AUDIO=PIPEWIRE"; elif [ -S /run/user/1000/pulse/native ]; then echo "AUDIO=PULSE"; else echo "AUDIO=NONE"; fi
  for m in .claude data exchange portal work upstream; do
    test -d "/home/claude/$m" && echo "MOUNT_${m}=OK" || echo "MOUNT_${m}=MISSING"
  done
'
VM_RESULTS=$(incus exec "$CONTAINER_NAME" --user 1000 --group 1000 -- bash -lc "$VM_CHECK_SCRIPT" 2>/dev/null || echo "")

get_val() { echo "$VM_RESULTS" | grep "^$1=" | cut -d= -f2- | tr -d '[:space:]'; }

show_version() {
  local label="$1"
  local actual="$2"

  if [ -z "$actual" ] || [ "$actual" = "MISSING" ]; then
    printf "  %-14s ${RED}NOT INSTALLED${NC}\n" "$label:"
  else
    printf "  %-14s ${GREEN}%s${NC}\n" "$label:" "$actual"
  fi
}

show_version "Bun" "$(get_val BUN)"
show_version "Claude Code" "$(get_val CLAUDE)"
show_version "Node.js" "$(get_val NODE)"

PAI_STATUS=$(get_val PAI)
[ "$PAI_STATUS" = "YES" ] && printf "  %-14s ${GREEN}installed${NC}\n" "PAI:" || printf "  %-14s ${RED}not found${NC}\n" "PAI:"

COMP_STATUS=$(get_val COMPANION)
[ "$COMP_STATUS" = "YES" ] && printf "  %-14s ${GREEN}cloned${NC}\n" "Companion:" || printf "  %-14s ${YELLOW}not cloned${NC}\n" "Companion:"

# Audio (already fetched in batch)
echo ""
echo -e "  ${BOLD}Audio${NC}"
AUDIO_STATUS=$(get_val AUDIO)
case "$AUDIO_STATUS" in
  PIPEWIRE) echo -e "  Socket:     ${GREEN}PipeWire connected${NC}" ;;
  PULSE)    echo -e "  Socket:     ${GREEN}PulseAudio connected${NC}" ;;
  NONE)     echo -e "  Socket:     ${YELLOW}No audio socket${NC} (is PipeWire running on host?)" ;;
  *)        echo -e "  Socket:     ${RED}Unknown${NC}" ;;
esac

# Mounts (already fetched in batch)
echo ""
echo -e "  ${BOLD}Shared Mounts${NC}"
for mount in .claude data exchange portal work upstream; do
  MOUNT_VAL=$(get_val "MOUNT_${mount}")
  if [ "$MOUNT_VAL" = "OK" ]; then
    printf "  %-14s ${GREEN}mounted${NC}\n" "$mount:"
  else
    printf "  %-14s ${RED}missing${NC}\n" "$mount:"
  fi
done

echo ""
